# FarmTwin environment variables — copy to .env and fill in values.
# NEVER commit .env to git.

# ── Anthropic (AI code review bot) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub (CI bot) ─────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ── Weather APIs ────────────────────────────────────────────────────
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point

# ── WhatsApp Business API ───────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ── Cloud DB ────────────────────────────────────────────────────────
TIMESCALEDB_URL=postgresql://user:pass@host:5432/farmtwin
DATABASE_URL=postgresql://user:pass@host:5432/farmtwin

# ── IoT / LoRaWAN ───────────────────────────────────────────────────
CHIRPSTACK_API_TOKEN=
CHIRPSTACK_SERVER=http://localhost:8080
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ── TDD mode (on = red phase; off = production) ─────────────────────
FARMTWIN_TDD_MODE=off
